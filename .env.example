# HBC Campaign Report Automation — Environment Variables
# On Vercel: Set these in Dashboard → Settings → Environment Variables
# Locally: Copy this to .env and fill in values

# ── Meta / Facebook Ads ──
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_
META_APP_ID=
META_APP_SECRET=
META_API_VERSION=v21.0

# ── Google Ads (YouTube) ──
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# ── Email Notifications ──
EMAIL_ENABLED=false
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_RECIPIENTS=

# ── Cron Security (optional) ──
CRON_SECRET=
