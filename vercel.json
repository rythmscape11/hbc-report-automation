{
    "version": 2,
    "functions": {
        "api/index.py": {
            "maxDuration": 60
        }
    },
    "builds": [
        {
            "src": "api/index.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "api/index.py"
        },
        {
            "src": "/(.*)",
            "dest": "api/index.py"
        }
    ],
    "env": {
        "META_ACCESS_TOKEN": "",
        "META_AD_ACCOUNT_ID": "",
        "META_APP_ID": "",
        "META_APP_SECRET": "",
        "GOOGLE_ADS_DEVELOPER_TOKEN": "",
        "GOOGLE_ADS_CLIENT_ID": "",
        "GOOGLE_ADS_CLIENT_SECRET": "",
        "GOOGLE_ADS_REFRESH_TOKEN": "",
        "GOOGLE_ADS_CUSTOMER_ID": "",
        "GOOGLE_ADS_LOGIN_CUSTOMER_ID": "",
        "EMAIL_ENABLED": "false"
    },
    "crons": [
        {
            "path": "/api/cron/daily",
            "schedule": "0 3 * * *"
        },
        {
            "path": "/api/cron/weekly",
            "schedule": "0 3 * * 1"
        },
        {
            "path": "/api/cron/monthly",
            "schedule": "0 3 1 * *"
        }
    ]
}
